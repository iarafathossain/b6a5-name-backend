<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="x-ua-compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OTP Verification</title>
  </head>
  <body
    style="
      margin: 0;
      padding: 0;
      background-color: #f5f8fc;
      font-family: Arial, Helvetica, sans-serif;
      color: #1f2937;
    "
  >
    <table
      role="presentation"
      width="100%"
      cellspacing="0"
      cellpadding="0"
      border="0"
      style="background-color: #f5f8fc; padding: 32px 16px"
    >
      <tr>
        <td align="center">
          <table
            role="presentation"
            width="100%"
            cellspacing="0"
            cellpadding="0"
            border="0"
            style="
              max-width: 640px;
              background-color: #ffffff;
              border-radius: 20px;
              overflow: hidden;
              box-shadow: 0 12px 32px rgba(15, 23, 42, 0.08);
            "
          >
            <tr>
              <td
                style="
                  padding: 32px 32px 24px 32px;
                  background: linear-gradient(135deg, #104b7e 0%, #0f172a 100%);
                  color: #ffffff;
                "
              >
                <img
                  src="cid:company-logo"
                  alt="Company logo"
                  width="132"
                  style="
                    display: block;
                    height: auto;
                    max-width: 132px;
                    margin: 0 0 20px 0;
                  "
                />
                <p
                  style="
                    margin: 0 0 10px 0;
                    font-size: 13px;
                    letter-spacing: 0.08em;
                    text-transform: uppercase;
                    color: rgba(255, 255, 255, 0.82);
                  "
                >
                  One-time password
                </p>
                <h1
                  style="
                    margin: 0;
                    font-size: 30px;
                    line-height: 1.2;
                    font-weight: 700;
                  "
                >
                  Secure verification code
                </h1>
                <p
                  style="
                    margin: 12px 0 0 0;
                    font-size: 15px;
                    line-height: 24px;
                    color: rgba(255, 255, 255, 0.92);
                  "
                >
                  Use the code below to complete your verification or password
                  reset request.
                </p>
              </td>
            </tr>

            <tr>
              <td style="padding: 32px">
                <p
                  style="
                    margin: 0 0 12px 0;
                    font-size: 16px;
                    line-height: 24px;
                    color: #111827;
                  "
                >
                  Hello <strong><%= name %></strong>,
                </p>
                <p
                  style="
                    margin: 0 0 24px 0;
                    font-size: 15px;
                    line-height: 24px;
                    color: #4b5563;
                  "
                >
                  We received a request that requires verification. Enter the
                  code below in the application to continue.
                </p>

                <table
                  role="presentation"
                  width="100%"
                  cellspacing="0"
                  cellpadding="0"
                  border="0"
                  style="margin: 0 0 24px 0"
                >
                  <tr>
                    <td align="center" style="padding: 0">
                      <table
                        role="presentation"
                        cellspacing="0"
                        cellpadding="0"
                        border="0"
                      >
                        <tr>
                          <td
                            style="
                              background-color: #fff7f0;
                              border: 1px solid #ffd2b8;
                              border-radius: 16px;
                              padding: 18px 28px;
                              letter-spacing: 0.35em;
                              font-size: 30px;
                              font-weight: 700;
                              color: #fa6000;
                            "
                          >
                            <%= otp %>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <table
                  role="presentation"
                  width="100%"
                  cellspacing="0"
                  cellpadding="0"
                  border="0"
                  style="
                    background-color: #f8fbff;
                    border: 1px solid #e5e7eb;
                    border-radius: 16px;
                    margin: 0 0 24px 0;
                  "
                >
                  <tr>
                    <td style="padding: 18px 20px">
                      <p
                        style="
                          margin: 0 0 6px 0;
                          font-size: 13px;
                          line-height: 20px;
                          font-weight: 700;
                          color: #104b7e;
                        "
                      >
                        Important
                      </p>
                      <p
                        style="
                          margin: 0;
                          font-size: 14px;
                          line-height: 22px;
                          color: #4b5563;
                        "
                      >
                        This code expires in 2 minutes. For your security, never
                        share it with anyone.
                      </p>
                    </td>
                  </tr>
                </table>

                <p
                  style="
                    margin: 0;
                    font-size: 14px;
                    line-height: 22px;
                    color: #6b7280;
                  "
                >
                  If you did not request this email, you can safely ignore it.
                </p>
              </td>
            </tr>

            <tr>
              <td style="padding: 0 32px 32px 32px">
                <table
                  role="presentation"
                  width="100%"
                  cellspacing="0"
                  cellpadding="0"
                  border="0"
                  style="border-top: 1px solid #e5e7eb"
                >
                  <tr>
                    <td
                      style="
                        padding-top: 20px;
                        font-size: 12px;
                        line-height: 18px;
                        color: #64748b;
                      "
                    >
                      <strong style="color: #104b7e">Support:</strong> If you
                      need help, contact the support team from the application.
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
